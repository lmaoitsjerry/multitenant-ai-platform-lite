# ============================================================
# Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Core ---
ENVIRONMENT=development          # development | production
PORT=8000
HOST=127.0.0.1
RELOAD=false                     # Auto-reload on code changes (dev only)
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
JSON_LOGS=true                   # Structured JSON logging

# --- Supabase (required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_ANON_KEY=your-anon-key

# --- Default Tenant ---
CLIENT_ID=example                # Default tenant if X-Client-ID header not provided

# --- Admin ---
ADMIN_API_TOKEN=                 # Token for /api/v1/admin/ endpoints
ADMIN_API_KEY=                   # Key for provisioning endpoints

# --- AI / LLM ---
OPENAI_API_KEY=                  # OpenAI API key (for email parsing, quote generation)
GOOGLE_API_KEY=                  # Google Gemini API key (alternative to OpenAI)
GEMINI_API_KEY=                  # Alias for GOOGLE_API_KEY

# --- Email (SendGrid) ---
SENDGRID_MASTER_API_KEY=         # Master SendGrid key for multi-tenant email
INBOUND_EMAIL_DOMAIN=holidaytoday.co.za   # Shared domain for tenant inbound email ({tenant}@{domain})

# --- Voice (Vapi / Twilio) ---
VAPI_API_KEY=                    # Vapi.ai API key for voice agents
TWILIO_ACCOUNT_SID=              # Twilio Account SID
TWILIO_AUTH_TOKEN=               # Twilio Auth Token

# --- Google Cloud ---
GCP_PROJECT_ID=                  # GCP project for BigQuery, Cloud Storage
GCP_REGION=us-central1

# --- Travel Platform Integration ---
TRAVEL_PLATFORM_URL=http://localhost:8080
TRAVEL_PLATFORM_API_KEY=
TRAVEL_PLATFORM_TENANT=itc-platform

# --- Knowledge Base ---
KNOWLEDGE_STORAGE_BACKEND=supabase    # supabase | gcs
RAG_BUCKET_NAME=                      # GCS bucket for RAG documents

# --- Observability (optional) ---
ENABLE_TRACING=false             # OpenTelemetry tracing
OTEL_SERVICE_NAME=multitenant-ai-platform
GOOGLE_CLOUD_PROJECT=            # For Cloud Trace exporter

# --- Security (optional) ---
CORS_ORIGINS=                    # Comma-separated allowed origins
SECURITY_CSP=                    # Custom Content-Security-Policy header
PII_AUDIT_ENABLED=true           # PII access audit logging

# --- Performance (optional) ---
REDIS_URL=                       # Redis URL for rate limiting / caching
BASE_URL=http://localhost:8000   # Public-facing URL for webhooks
